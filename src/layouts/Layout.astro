---
import "../styles/global.css";
import "../styles/utilities.css";
import "../styles/buttons.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Geoingeniería Ltda | Ingeniería que Transforma el Territorio",
  description = "Geoingeniería Ltda — Empresa especializada en ingeniería civil, geotecnia, proyectos viales y obras hidráulicas con más de 25 años de experiencia.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
    <!-- Anti-flash: apply theme before first paint -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("geo-theme");
        const preferred = window.matchMedia("(prefers-color-scheme: light)")
          .matches
          ? "light"
          : "dark";
        document.documentElement.setAttribute(
          "data-theme",
          stored || preferred,
        );
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Ir al contenido principal</a>
    <slot />
  </body>
</html>
