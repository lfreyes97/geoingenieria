---
// Footer 5: Estilo Grid App Moderno (Estructurado y de alto contraste)
import Logo from "./Logo.astro";
---

<footer class="footer-5">
  <div class="f5-container">
    <div class="f5-top-grid">
      <div class="f5-card brand-card">
        <div class="logo" style="margin-bottom: 16px;">
          <Logo height="32px" />
        </div>
        <p>
          Expertos en geotecnia, obras viales e infraestructura civil conectando
          al país.
        </p>
        <a href="/contacto" class="btn-dark"
          >Contáctenos <i
            class="fa-solid fa-arrow-turn-up"
            style="transform: rotate(90deg)"></i></a
        >
      </div>

      <div class="f5-card link-card">
        <h4>Navegación</h4>
        <nav>
          <a href="/#inicio">Inicio</a>
          <a href="/#servicios">Servicios</a>
          <a href="/#proyectos">Proyectos</a>
          <a href="/#nosotros">Empresa</a>
        </nav>
      </div>

      <div class="f5-card link-card">
        <h4>Servicios Clave</h4>
        <nav>
          <a href="#">Obras Viales</a>
          <a href="#">Estudios Geotécnicos</a>
          <a href="#">Gestión Ambiental</a>
          <a href="#">Infraestructura</a>
        </nav>
      </div>

      <div class="f5-card newsletter-card">
        <h4>Manténgase al día</h4>
        <p>Reciba actualizaciones trimestrales de nuestros proyectos.</p>
        <form class="f5-form" onsubmit="event.preventDefault();">
          <input type="email" placeholder="correo@empresa.com" required />
          <button type="submit"><i class="fa-solid fa-arrow-right"></i></button>
        </form>
      </div>
    </div>

    <div class="f5-bottom-bar">
      <div class="f5-legal">
        <span>© {new Date().getFullYear()} Geoingeniería.</span>
        <a href="#">Privacidad</a>
        <a href="#">Términos</a>
      </div>
      <div class="f5-socials">
        <a href="#">LinkedIn</a>
        <a href="#">Instagram</a>
        <a href="#">Facebook</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-5 {
    background: #040d17; /* Very dark blue, almost black */
    padding: 60px 0 20px;
    font-family: var(--ff-body);
    color: var(--clr-text-muted);
  }
  .f5-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 40px);
  }

  .f5-top-grid {
    display: grid;
    grid-template-columns: 2.5fr 1fr 1.5fr 2fr;
    gap: 24px;
    margin-bottom: 40px;
  }

  .f5-card {
    background: rgba(255, 255, 255, 0.03);
    border-radius: 20px;
    padding: 40px 30px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: background 0.3s;
  }
  .f5-card:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  .brand-card .logo {
    font-family: var(--ff-head);
    color: #fff;
    font-size: 1.3rem;
    font-weight: 600;
    margin-bottom: 16px;
  }
  .brand-card p {
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 30px;
    max-width: 90%;
  }
  .btn-dark {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #112844;
    color: #fff;
    padding: 12px 24px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 500;
    transition: 0.3s;
  }
  .btn-dark:hover {
    background: var(--clr-gold);
    color: #fff;
  }

  .link-card h4,
  .newsletter-card h4 {
    color: #fff;
    font-family: var(--ff-head);
    font-size: 1.1rem;
    margin-bottom: 24px;
  }
  .link-card nav {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .link-card a {
    color: inherit;
    text-decoration: none;
    transition: 0.3s;
  }
  .link-card a:hover {
    color: var(--clr-white);
  }

  .newsletter-card p {
    font-size: 0.9rem;
    margin-bottom: 20px;
  }
  .f5-form {
    display: flex;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 4px;
  }
  .f5-form input {
    flex: 1;
    background: transparent;
    border: none;
    padding: 12px 16px;
    color: #fff;
    outline: none;
  }
  .f5-form button {
    background: var(--clr-gold);
    color: #fff;
    border: none;
    border-radius: 6px;
    width: 44px;
    cursor: pointer;
    transition: 0.3s;
  }
  .f5-form button:hover {
    background: var(--clr-gold-dark);
  }

  .f5-bottom-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    font-size: 0.9rem;
  }
  .f5-legal,
  .f5-socials {
    display: flex;
    gap: 20px;
    align-items: center;
  }
  .f5-bottom-bar a {
    color: inherit;
    text-decoration: none;
    transition: 0.3s;
  }
  .f5-bottom-bar a:hover {
    color: #fff;
  }

  @media (max-width: 1100px) {
    .f5-top-grid {
      grid-template-columns: 1fr 1fr;
    }
    .brand-card {
      grid-column: span 2;
    }
  }
  @media (max-width: 768px) {
    .f5-top-grid {
      grid-template-columns: 1fr;
    }
    .brand-card {
      grid-column: span 1;
    }
    .f5-bottom-bar {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
