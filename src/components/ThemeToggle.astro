---
// ThemeToggle component — persists preference via localStorage
interface Props {
  classes?: {
    toggle?: string;
    moon?: string;
    sun?: string;
  };
}

const { classes = {} } = Astro.props;
---

<button
  id="theme-toggle"
  class={`theme-toggle ${classes.toggle || ""}`}
  aria-label="Cambiar tema"
  title="Cambiar tema claro / oscuro"
>
  <!-- Moon icon (shown in light mode → click to go dark) -->
  <svg
    class={`icon-moon ${classes.moon || ""}`}
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="currentColor"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z"></path>
  </svg>
  <!-- Sun icon (shown in dark mode → click to go light) -->
  <svg
    class={`icon-sun ${classes.sun || ""}`}
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>
</button>

<script>
  // ThemeToggle logic
  // Transitions are disabled on page load by Layout.astro logic if needed,
  // but here we just handle the toggle.

  function initThemeToggle() {
    const html = document.documentElement;
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;

    btn.addEventListener("click", () => {
      const current = html.getAttribute("data-theme") ?? "dark";
      const next = current === "dark" ? "light" : "dark";

      html.setAttribute("data-theme", next);
      localStorage.setItem("geo-theme", next);
    });
  }

  // Runs on initial load
  initThemeToggle();

  // Runs on View Transitions (if enabled in future)
  document.addEventListener("astro:after-swap", initThemeToggle);
</script>
