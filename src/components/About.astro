---
import { Image } from 'astro:assets';
import geoSurveyImg from '../assets/images/geo_survey.png';

// About component — Geoingeniería Ltda
const values = [
  { icon: "fa-shield-halved", title: "Seguridad" },
  { icon: "fa-microscope", title: "Rigor Técnico" },
  { icon: "fa-handshake", title: "Compromiso" },
];

const certifications = [
  "Certificación ISO 9001:2015",
  "Registro BNE — MOP",
  "Acreditación SERNAGEOMIN",
  "Proveedor ENAP & CODELCO",
];
---

<section class="about" id="nosotros">
  <div class="content">
    <div class="text">
      <span class="section-tag">Quiénes somos</span>
      <h2 class="section-title">
        Más de dos décadas<br /><span class="text-accent"
          >construyendo Colombia</span
        >
      </h2>
      <p>
        Desde 1999, Geoingeniería Ltda lidera proyectos de geotecnia e
        infraestructura en Colombia. Nuestro equipo de más de 80 profesionales
        integra rigor técnico e innovación para superar las expectativas en cada
        obra civil compleja.
      </p>

      <div class="values">
        {
          values.map((v) => (
            <div class="valueItem" data-reveal>
              <div class="valueIcon">
                <i class={`fa-solid ${v.icon}`} />
              </div>
              <h4>{v.title}</h4>
            </div>
          ))
        }
      </div>

      <a href="#contacto" class="btn-primary">
        Trabaja con Nosotros <i class="fa-solid fa-arrow-right"></i>
      </a>
    </div>

    <div class="visual">
      <div class="imgWrap" data-reveal>
        <Image src={geoSurveyImg} alt="Equipo Geoingeniería Ltda" />
        <div class="badge">
          <span class="badgeNum">ISO</span>
          <span class="badgeText">9001:2015<br />Certificados</span>
        </div>
      </div>
      <div class="certifications">
        {
          certifications.map((cert) => (
            <div class="certItem">
              <i class="fa-solid fa-certificate" /> {cert}
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
