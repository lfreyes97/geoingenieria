---
// Navbar 3: Doble Barra Superior
// Barra finita arriba con info de contacto, barra principal abajo con logo centrado
---

<header class="navbar-3">
  <!-- Top Bar -->
  <div class="n3-top">
    <div class="n3-top-inner">
      <div class="n3-contact">
        <span><i class="fa-solid fa-phone"></i> +56 2 2345 6789</span>
        <span
          ><i class="fa-solid fa-envelope"></i> proyectos@geoingenieria.cl</span
        >
      </div>
      <div class="n3-social">
        <a href="#"><i class="fa-brands fa-linkedin"></i></a>
        <a href="#"><i class="fa-brands fa-facebook"></i></a>
      </div>
    </div>
  </div>

  <!-- Main Bar -->
  <div class="n3-main">
    <nav class="n3-links">
      <a href="/#inicio">Inicio</a>
      <a href="/#servicios">Servicios</a>
    </nav>

    <a href="/" class="n3-logo">
      <span class="l-geo">Geo </span><span class="l-ing">ingeniería</span>
    </a>

    <nav class="n3-links">
      <a href="/#proyectos">Proyectos</a>
      <a href="/contacto">Contacto</a>
    </nav>
  </div>
</header>

<style>
  .navbar-3 {
    font-family: var(--ff-body);
    width: 100%;
    background: var(--clr-surface, #ffffff);
    color: var(--clr-text, #333);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  /* Top Bar */
  .n3-top {
    background: var(--clr-bg2, #0b1d30);
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.85rem;
    padding: 8px 0;
  }
  .n3-top-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 40px);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .n3-contact {
    display: flex;
    gap: 20px;
  }
  .n3-contact i {
    color: var(--clr-gold);
    margin-right: 5px;
  }
  .n3-social a {
    color: inherit;
    margin-left: 15px;
    transition: color 0.3s;
  }
  .n3-social a:hover {
    color: var(--clr-white);
  }

  /* Main Bar */
  .n3-main {
    max-width: 1400px;
    margin: 0 auto;
    height: 90px;
    padding: 0 clamp(20px, 4vw, 40px);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .n3-logo {
    text-decoration: none;
    font-family: var(--ff-head);
    font-size: 1.8rem;
    font-weight: 800;
  }
  .l-geo {
    color: var(--clr-text, #111);
  }
  .l-ing {
    color: var(--clr-gold);
  }

  .n3-links {
    display: flex;
    gap: 40px;
    flex: 1;
  }
  /* Empujar el segundo nav a la derecha */
  .n3-main .n3-links:last-child {
    justify-content: flex-end;
  }

  .n3-links a {
    color: var(--clr-text-muted, #555);
    text-decoration: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 1px;
    transition: color 0.3s;
  }
  .n3-links a:hover {
    color: var(--clr-gold);
  }
</style>
