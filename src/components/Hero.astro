---
// Hero component — Geoingeniería Ltda
---

<section class="hero" id="main-content" aria-label="Inicio">
  <div class="bg">
    <img src="/images/Hero.png" alt="Obras de ingeniería civil" class="img" />
    <div class="overlay"></div>
  </div>

  <div class="content">
    <div class="badge">
      <span class="badgeDot"></span>
      Más de 25 años de experiencia
    </div>
    <h1 class="title">
      Ingeniería que<br />
      <span class="accent">Transforma</span><br />
      el Territorio
    </h1>
    <p class="desc">
      Soluciones especializadas en geotecnia, obras civiles e infraestructura
      vial, diseñadas con precisión técnica e innovación para los proyectos más
      exigentes de Colombia y Latinoamérica.
    </p>
    <div class="actions">
      <a href="#proyectos" class="btn-primary">
        Ver Proyectos <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
      </a>
      <a href="#servicios" class="btn-outline">Nuestros Servicios</a>
    </div>
  </div>

  <div class="stats" data-hero-stats>
    <div class="statItem">
      <span class="statNumber" data-stat-number data-target="350" data-suffix=""
        >+350</span
      >
      <span class="statLabel">Proyectos completados</span>
    </div>
    <div class="statDivider"></div>
    <div class="statItem">
      <span class="statNumber" data-stat-number data-target="25" data-suffix="+"
        >25+</span
      >
      <span class="statLabel">Años de experiencia</span>
    </div>
    <div class="statDivider"></div>
    <div class="statItem">
      <span class="statNumber" data-stat-number data-target="12" data-suffix=""
        >12</span
      >
      <span class="statLabel">Departamentos en Colombia</span>
    </div>
    <div class="statDivider"></div>
    <div class="statItem">
      <span class="statNumber" data-stat-number data-target="98" data-suffix="%"
        >98%</span
      >
      <span class="statLabel">Clientes satisfechos</span>
    </div>
  </div>

  <div class="scroll">
    <span>Descubrir más</span>
    <div class="scrollArrow">
      <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
    </div>
  </div>
</section>

<script>
  // Counter animation
  function animateCounter(el: HTMLElement, target: number, suffix: string) {
    let count = 0;
    const step = Math.ceil(target / 60);
    const interval = setInterval(() => {
      count = Math.min(count + step, target);
      el.textContent = "+" + count + suffix;
      if (count >= target) clearInterval(interval);
    }, 25);
  }

  const statsObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          document
            .querySelectorAll<HTMLElement>("[data-stat-number]")
            .forEach((el) => {
              const target = parseInt(el.dataset.target || "0");
              const suffix = el.dataset.suffix || "";
              el.textContent = "0";
              animateCounter(el, target, suffix);
            });
          statsObserver.disconnect();
        }
      });
    },
    { threshold: 0.5 },
  );

  const statsEl = document.querySelector("[data-hero-stats]");
  if (statsEl) statsObserver.observe(statsEl);
</script>
