---
// Footer component — Geoingeniería Ltda
const mainLinks = [
  { label: "Inicio", href: "/#inicio" },
  { label: "Servicios", href: "/#servicios" },
  { label: "Proyectos", href: "/#proyectos" },
  { label: "Quiénes Somos", href: "/#nosotros" },
  { label: "Contacto", href: "/contacto" },
];
---

<footer class="footer-minimal">
  <div class="inner">
    <a href="/#inicio" class="nav-logo centered-logo">
      <div class="logo-icon">
        <svg
          width="40"
          height="40"
          viewBox="0 0 36 36"
          fill="none"
          aria-hidden="true"
        >
          <polygon
            points="18,2 34,30 2,30"
            stroke="var(--clr-gold)"
            stroke-width="2.5"
            fill="none"></polygon>
          <polygon
            points="18,10 28,28 8,28"
            fill="var(--clr-gold)"
            opacity="0.25"></polygon>
          <line
            x1="18"
            y1="2"
            x2="18"
            y2="30"
            stroke="var(--clr-gold)"
            stroke-width="1.5"
            opacity="0.7"></line>
        </svg>
      </div>
      <div class="logo-text">
        <span class="logo-main">Geoingeniería</span>
        <span class="logo-sub">Ltda</span>
      </div>
    </a>

    <nav class="footer-nav">
      <ul>
        {
          mainLinks.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="social-links">
      <a href="#" class="social-icon" aria-label="LinkedIn">
        <i class="fa-brands fa-linkedin-in"></i>
      </a>
      <a href="#" class="social-icon" aria-label="Facebook">
        <i class="fa-brands fa-facebook-f"></i>
      </a>
      <a href="#" class="social-icon" aria-label="Instagram">
        <i class="fa-brands fa-instagram"></i>
      </a>
    </div>

    <div class="footer-bottom">
      <p>
        © {new Date().getFullYear()} Geoingeniería Ltda. Todos los derechos reservados.<br
        />
        NIT: 900.123.456-7 | Riohacha - La Guajira, Colombia
      </p>
    </div>
  </div>
</footer>
