---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .sort((a, b) => {
    const featuredDiff = Number(b.data.featured) - Number(a.data.featured);
    if (featuredDiff !== 0) return featuredDiff;
    const orderDiff = a.data.order - b.data.order;
    if (orderDiff !== 0) return orderDiff;
    return b.data.year - a.data.year;
  })
  .slice(0, 3);
---

<section class="projects" id="proyectos">
  <div class="section-header light">
    <span class="section-tag">Nuestro trabajo</span>
    <h2 class="section-title">Proyectos <span class="text-accent">Destacados</span></h2>
    <p class="section-desc">
      Una selección de los proyectos más significativos que hemos desarrollado a
      lo largo de nuestra trayectoria.
    </p>
  </div>

  <div class="grid">
    {projects.map((project, index) => (
      <div class={`card${index === 0 ? " large" : ""}`} id={`proj-${project.slug}`} data-reveal>
        <Image
          src={project.data.cover}
          alt={project.data.coverAlt}
          loading={index === 0 ? "eager" : "lazy"}
        />
        <div class="overlay">
          <div class="tag">{project.data.category}</div>
          <h3>{project.data.title}</h3>
          <p>{project.data.summary}</p>
          <a href={`/proyectos/${project.slug}`} class="btn">Ver detalles</a>
        </div>
      </div>
    ))}
  </div>

  <div class="cta">
    <a href="/portafolio" class="btn-primary">
      Ver Todos los Proyectos <i class="fa-solid fa-arrow-right"></i>
    </a>
  </div>
</section>
