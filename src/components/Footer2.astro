---
// Footer 2: Minimalista Centrado (Elegante)
import Logo from "./Logo.astro";
---

<footer class="footer-2">
  <div class="footer-2-inner">
    <div class="f2-brand">
      <Logo height="60px" class="logo-image" />
    </div>

    <nav class="f2-nav">
      <a href="/#inicio">Inicio</a>
      <a href="/#servicios">Servicios</a>
      <a href="/#proyectos">Proyectos</a>
      <a href="/#nosotros">Nosotros</a>
      <a href="/contacto">Contacto</a>
    </nav>

    <div class="f2-socials">
      <a href="#"><i class="fa-brands fa-linkedin-in"></i></a>
      <a href="#"><i class="fa-brands fa-x-twitter"></i></a>
      <a href="#"><i class="fa-brands fa-instagram"></i></a>
    </div>

    <div class="f2-bottom">
      <p>
        © {new Date().getFullYear()} Geoingeniería. Todos los derechos reservados.<br
        />
        Riohacha, La Guajira - Colombia
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-2 {
    background: var(--clr-bg2, #0b1d30);
    padding: 100px 0 50px;
    text-align: center;
    border-top: 1px solid var(--clr-border);
  }
  .footer-2-inner {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .f2-brand {
    margin-bottom: 40px;
  }
  .f2-brand .logo-icon {
    margin-bottom: 16px;
    display: inline-block;
  }
  .f2-brand h3 {
    color: var(--clr-white);
    font-family: var(--ff-head);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: 1px;
  }

  .f2-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 30px;
    margin-bottom: 40px;
  }
  .f2-nav a {
    color: var(--clr-text-muted);
    font-weight: 500;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: color 0.3s;
    text-decoration: none;
  }
  .f2-nav a:hover {
    color: var(--clr-gold);
  }

  .f2-socials {
    display: flex;
    gap: 20px;
    margin-bottom: 50px;
  }
  .f2-socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: var(--clr-white);
    transition: all 0.3s;
  }
  .f2-socials a:hover {
    background: var(--clr-gold);
    border-color: var(--clr-gold);
    transform: translateY(-3px);
  }

  .f2-bottom p {
    color: var(--clr-text-muted);
    font-size: 0.85rem;
    line-height: 1.8;
  }
</style>
