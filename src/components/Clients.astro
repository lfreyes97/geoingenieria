---
// Clients marquee component — Geoingeniería Ltda
const clients = ['MOP', 'CODELCO', 'ENAP', 'GORE Biobío', 'Serviu', 'AES Gener'];
---

<section class="clients">
  <div class="inner">
    <p class="label">Confían en nosotros</p>
    <div class="logos">
      {[...clients, ...clients].map((c, i) => (
        <span class="logo" key={i}>{c}</span>
      ))}
    </div>
  </div>
</section>
