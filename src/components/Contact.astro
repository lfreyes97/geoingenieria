---
// Contact component — Geoingeniería Ltda
const infoCards = [
  {
    icon: 'fa-location-dot',
    title: 'Oficina Central',
    lines: ['Sede Principal', 'Riohacha - La Guajira, Colombia'],
  },
  {
    icon: 'fa-phone',
    title: 'Teléfono',
    lines: ['+56 2 2345 6789', '+56 9 8765 4321'],
  },
  {
    icon: 'fa-envelope',
    title: 'Correo',
    lines: ['contacto@geoingenieria.cl', 'proyectos@geoingenieria.cl'],
  },
  {
    icon: 'fa-clock',
    title: 'Horario de atención',
    lines: ['Lunes a Viernes: 8:30 – 18:00', 'Sábado: 9:00 – 13:00'],
  },
];
---

<section class="contact" id="contacto">
  <div class="section-header">
    <span class="section-tag">Contáctenos</span>
    <h2 class="section-title">¿Tiene un <span class="text-accent">Proyecto</span> en mente?</h2>
    <p class="section-desc">
      Complete el formulario y nuestro equipo técnico se comunicará con usted
      dentro de las próximas 24 horas.
    </p>
  </div>

  <div class="grid">
    <form class="form" id="contact-form" novalidate>
      <div class="formRow">
        <div class="formGroup">
          <label for="name">Nombre completo *</label>
          <input type="text" id="name" name="name" placeholder="Ej.: Carlos Muñoz" required />
        </div>
        <div class="formGroup">
          <label for="company">Empresa</label>
          <input type="text" id="company" name="company" placeholder="Ej.: Constructora XYZ Ltda" />
        </div>
      </div>
      <div class="formRow">
        <div class="formGroup">
          <label for="email">Correo electrónico *</label>
          <input type="email" id="email" name="email" placeholder="correo@empresa.cl" required />
        </div>
        <div class="formGroup">
          <label for="phone">Teléfono</label>
          <input type="tel" id="phone" name="phone" placeholder="+56 9 1234 5678" />
        </div>
      </div>
      <div class="formGroup">
        <label for="service">Servicio de interés *</label>
        <select id="service" name="service" required>
          <option value="" disabled selected>Seleccione un servicio…</option>
          <option>Estudios Geotécnicos</option>
          <option>Obras Viales</option>
          <option>Obras Hidráulicas</option>
          <option>Infraestructura Civil</option>
          <option>Asesoría y Diseño</option>
          <option>Gestión Ambiental</option>
          <option>Otro</option>
        </select>
      </div>
      <div class="formGroup">
        <label for="message">Descripción del proyecto *</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          placeholder="Cuéntenos brevemente sobre su proyecto, ubicación, plazo estimado y cualquier detalle relevante…"
          required
        ></textarea>
      </div>
      <button type="submit" class="btn-primary submit" id="submit-btn">
        Enviar Consulta <i class="fa-solid fa-paper-plane"></i>
      </button>
      <div class="success" id="form-success">
        <i class="fa-solid fa-circle-check"></i>
        ¡Consulta enviada! Nos contactaremos pronto.
      </div>
    </form>

    <div class="info">
      {infoCards.map(card => (
        <div class="infoCard" data-reveal>
          <div class="infoIcon">
            <i class={`fa-solid ${card.icon}`}></i>
          </div>
          <div>
            <h4>{card.title}</h4>
            <p set:html={card.lines.join('<br />')} />
          </div>
        </div>
      ))}

      <div class="socialRow">
        <a href="#" class="socialBtn" aria-label="LinkedIn">
          <i class="fa-brands fa-linkedin-in"></i>
        </a>
        <a href="#" class="socialBtn" aria-label="Facebook">
          <i class="fa-brands fa-facebook-f"></i>
        </a>
        <a href="#" class="socialBtn" aria-label="Instagram">
          <i class="fa-brands fa-instagram"></i>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form.addEventListener('submit', e => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Enviando…';
    setTimeout(() => {
      submitBtn.style.display = 'none';
      successMsg.style.display = 'flex';
      form.reset();
    }, 1800);
  });
</script>
