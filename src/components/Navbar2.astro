---
// Navbar 2: Flotante Moderno (Pill)
// Ideal para fondos oscuros. Como una "píldora" centrada flotando.
---

<div class="wrapper-2">
  <header class="navbar-2">
    <a href="/" class="n2-logo">
      <svg width="24" height="24" viewBox="0 0 36 36" fill="none">
        <polygon
          points="18,2 34,30 2,30"
          stroke="var(--clr-gold)"
          stroke-width="2.5"></polygon>
      </svg>
      GEO
    </a>
    <nav class="n2-links">
      <a href="/#inicio">Inicio</a>
      <a href="/#servicios">Servicios</a>
      <a href="/#proyectos" class="active">Proyectos</a>
      <a href="/#nosotros">Empresa</a>
      <a href="/contacto">Contacto</a>
    </nav>
    <a href="/contacto" class="n2-icon"><i class="fa-solid fa-envelope"></i></a>
  </header>
</div>

<style>
  .wrapper-2 {
    background: var(
      --clr-bg,
      #081524
    ); /* Para que resalte la píldora oscura sobre el fondo */
    padding: 30px 20px;
    display: flex;
    justify-content: center;
  }
  .navbar-2 {
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50px;
    padding: 8px 12px 8px 24px;
    display: flex;
    align-items: center;
    gap: 40px;
    font-family: var(--ff-body);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }
  .n2-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: #fff;
    font-family: var(--ff-head);
    font-weight: 800;
    letter-spacing: 1px;
    font-size: 1.2rem;
  }
  .n2-links {
    display: flex;
    gap: 20px;
  }
  .n2-links a {
    color: var(--clr-text-muted, #ccc);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    padding: 6px 12px;
    border-radius: 20px;
    transition: all 0.3s;
  }
  .n2-links a:hover,
  .n2-links a.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }
  .n2-icon {
    width: 40px;
    height: 40px;
    background: var(--clr-gold);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: transform 0.3s;
    text-decoration: none;
  }
  .n2-icon:hover {
    transform: scale(1.1);
  }
</style>
