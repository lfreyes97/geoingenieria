---
// Navbar component — Geoingeniería Ltda
import ThemeToggle from "./ThemeToggle.astro";
import Logo from "./Logo.astro";

// Usamos el path actual para saber si estamos en el index o no
const currentPath = Astro.url.pathname;
const isHome = currentPath === "/" || currentPath === "/index.html";
---

<nav class="navbar" id="navbar">
  <div class="container">
    <a href={isHome ? "#inicio" : "/#inicio"} class="logo">
      <Logo height="48px" class="logo-image" />
    </a>

    <ul class="links" id="nav-links">
      <li>
        <a href={isHome ? "#inicio" : "/#inicio"} class="link" data-nav-link
          >Inicio</a
        >
      </li>
      <li>
        <a
          href={isHome ? "#servicios" : "/#servicios"}
          class="link"
          data-nav-link>Servicios</a
        >
      </li>
      <li>
        <a
          href={isHome ? "#proyectos" : "/#proyectos"}
          class="link"
          data-nav-link>Proyectos</a
        >
      </li>
      <li>
        <a href={isHome ? "#nosotros" : "/#nosotros"} class="link" data-nav-link
          >Nosotros</a
        >
      </li>
      <li><a href="/contacto" class="link" data-nav-link>Contacto</a></li>
    </ul>

    <a href="/contacto" class="cta">Cotizar Proyecto</a>

    <ThemeToggle
      classes={{ toggle: "themeToggle", sun: "iconSun", moon: "iconMoon" }}
    />

    <button
      class="hamburger"
      id="hamburger"
      aria-label="Menú de navegación"
      aria-expanded="false"
      aria-controls="nav-links"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<script>
  // Navbar scroll effect
  const navbar = document.getElementById("navbar")!;
  window.addEventListener("scroll", () => {
    if (window.scrollY > 60) {
      navbar.setAttribute("data-scrolled", "true");
    } else {
      navbar.removeAttribute("data-scrolled");
    }
  });

  // Hamburger menu
  const hamburger = document.getElementById("hamburger")!;
  const navLinks = document.getElementById("nav-links")!;

  hamburger.addEventListener("click", () => {
    const isActive = hamburger.toggleAttribute("data-active");
    hamburger.setAttribute("aria-expanded", String(isActive));
    if (isActive) {
      navLinks.setAttribute("data-open", "true");
    } else {
      navLinks.removeAttribute("data-open");
    }
  });

  navLinks.querySelectorAll("a").forEach((a) => {
    a.addEventListener("click", () => {
      hamburger.removeAttribute("data-active");
      hamburger.setAttribute("aria-expanded", "false");
      navLinks.removeAttribute("data-open");
    });
  });

  // Active nav link on scroll (only if sections exist on the page)
  const sections = document.querySelectorAll("section[id]");
  if (sections.length > 0) {
    const navLinkEls = document.querySelectorAll("[data-nav-link]");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            navLinkEls.forEach((l) => l.removeAttribute("data-active"));
            // Try to find exact match first (e.g., "#servicios" if home, "/#servicios" if not)
            let active = document.querySelector(
              `[data-nav-link][href$="#${entry.target.id}"]`,
            );
            if (active) active.setAttribute("data-active", "true");
          }
        });
      },
      { threshold: 0.4 },
    );
    sections.forEach((s) => observer.observe(s));
  } else {
    // If we're on a separate page (like contact), highlight the exact URL match
    const currentPath = window.location.pathname;
    const active = document.querySelector(
      `[data-nav-link][href="${currentPath}"]`,
    );
    if (active) active.setAttribute("data-active", "true");
  }

  // Smooth scroll - Modified to only apply for hash links on the SAME page
  // If we are on /contacto and click /#servicios, it should navigate normally.
  document.querySelectorAll('a[href^="#"], a[href^="/#"]').forEach((a) => {
    a.addEventListener("click", (e) => {
      const href = (a as HTMLAnchorElement).getAttribute("href")!;
      // Extract the hash part
      const hashIndex = href.indexOf("#");
      if (hashIndex !== -1) {
        const hash = href.substring(hashIndex);
        const target = document.querySelector(hash);

        // Only prevent default and smooth scroll if the target element exists on CURRENT page
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: "smooth" });
          // Optionally update URL to reflect hash
          history.pushState(null, "", hash);
        }
      }
    });
  });
</script>
